# ==== Database ====
# URL khi chạy backend LOCAL (ngoài Docker). Trong Docker, compose tự set DATABASE_URL.
DATABASE_URL=postgresql+psycopg://fintextsql:fintextsql@localhost:5432/fintextsql

# Thông tin Postgres dùng cho Docker Compose
POSTGRES_DB=fintextsql
POSTGRES_USER=fintextsql
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=55432

# ==== LLM (OpenAI-compatible Chat Completions) ====
# Endpoint khi chạy backend LOCAL
LLM_BASE_URL=http://localhost:20128/v1
# Endpoint khi backend chạy TRONG Docker (Linux dùng host.docker.internal)
DOCKER_LLM_BASE_URL=http://host.docker.internal:20128/v1
# Bắt buộc: API key của endpoint LLM
LLM_API_KEY=replace-with-your-key
# Tên model gửi vào endpoint
LLM_MODEL=local-model
# Timeout mỗi request LLM (giây)
LLM_TIMEOUT_SECONDS=60

# ==== Backend ====
# Số dòng tối đa cho mỗi truy vấn SQL
MAX_SQL_ROWS=2000
# Danh sách origin được phép (CORS), phân tách bằng dấu phẩy
CORS_ORIGINS=http://localhost:15173,http://127.0.0.1:15173,http://localhost:5173,http://127.0.0.1:5173
# Port backend trên máy host
BACKEND_PORT=18000

# ==== Frontend ====
FRONTEND_PORT=15173
# Base URL API của frontend (qua proxy /api để tránh CORS)
VITE_API_URL=/api

# ==== Tavily Web Search (cho câu hỏi fact-lookup như "CEO của Apple") ====
# Lấy key miễn phí tại https://app.tavily.com/home (1000 search/tháng)
TAVILY_API_KEY=tvly-replace-with-your-key
TAVILY_TIMEOUT_SECONDS=15

# ==== Cloudflare Tunnel (tuỳ chọn) ====
# Token tunnel; để trống nếu không dùng public access
CLOUDFLARE_TUNNEL_TOKEN=
